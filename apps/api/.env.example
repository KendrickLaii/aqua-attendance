# Database
DATABASE_URL=postgresql+asyncpg://attendance:attendance@localhost:5432/attendance
# Sync URL for Alembic (when running outside Docker)
DATABASE_URL_SYNC=postgresql+psycopg://attendance:attendance@localhost:5432/attendance

# Auth — local dev may use placeholders below.
# Server / UAT / production: generate TWO different random secrets (see docs/DEPLOY.md):
#   openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# QR signing — must differ from SECRET_KEY; same generation command as above.
QR_SECRET=change-me-qr-secret-use-openssl-rand-hex-32

# Same product cannot be scanned twice within this many seconds; the second
# scan returns the existing event (kiosk double-tap protection).
SCAN_DEBOUNCE_SECONDS=3

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:8081

# development = placeholders OK | production = API refuses weak/example secrets
ENV=development
