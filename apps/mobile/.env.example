# API base URL — must use EXPO_PUBLIC_ prefix for Expo to expose to the app.
#
# Android EMULATOR (Expo press a):
#   EXPO_PUBLIC_API_URL=http://10.0.2.2:8000/api
#
# Expo WEB (press w in terminal):
#   EXPO_PUBLIC_API_URL=http://localhost:8000/api
#
# Expo Go on PHYSICAL PHONE (same Wi-Fi) — also start API with:
#   python -m uvicorn app.main:app --reload --host 0.0.0.0
#   Use LAN IP from ipconfig (not 127.0.0.1):
# EXPO_PUBLIC_API_URL=http://192.168.1.50:8000/api
#
EXPO_PUBLIC_API_URL=http://localhost:8000/api
