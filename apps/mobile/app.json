{
  "expo": {
    "name": "AQUA Attendance",
    "slug": "aqua-attendance",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#160D47"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow AQUA Attendance to use the camera for QR code scanning."
        }
      ],
      "expo-asset",
      "expo-localization",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          },
          "ios": {
            "infoPlist": {
              "NSAppTransportSecurity": {
                "NSAllowsArbitraryLoads": true
              }
            }
          }
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aqua.attendance"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#160D47"
      },
      "package": "com.aqua.attendance",
      "versionCode": 2,
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "scheme": "aqua-attendance",
    "updates": {
      "enabled": false,
      "checkAutomatically": "NEVER"
    },
    "extra": {
      "eas": {
        "projectId": "101ab907-e883-4389-a3b8-492c19285d9b"
      }
    },
    "owner": "kendrickolo"
  }
}
