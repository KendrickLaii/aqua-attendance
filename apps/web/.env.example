# Attendance API (required for attendance pages)
# Baked into the web image at BUILD time (see .github/workflows/docker-publish.yml).
# For multi-server / multi-IP deploys, the SAME web:main image is pulled by every
# host, so this MUST be the relative path "/api" — each server's Caddy proxies
# /api/* to its own API container. Never hardcode a host IP/domain here (e.g.
# http://1.2.3.4/api), or every server's frontend will call that one backend.
# Local dev only: point it at your local API below.
VITE_ATTENDANCE_API_URL=http://localhost:8000/api

# Default label for web scanner check-in/out (e.g. branch or room name)
# VITE_ATTENDANCE_SCAN_LOCATION=Main classroom

# Optional — AQUA template demos only (not used by attendance)
VITE_MAPBOX_ACCESS_TOKEN=
VITE_AUTH_API_BASE_URL=
VITE_ENV_MODE=

# AQUA template demo mocks (MSW). Leave unset/false for real attendance API.
# VITE_USE_MSW=true
