# Public host(s). DNS A record → server IP (or use the same IP for both when testing without a domain).
APP_DOMAIN=app.example.com
# For IP-only UAT, set both to the same public IP, e.g. 13.115.90.135
API_DOMAIN=api.example.com

# NOTE: The frontend's API base (VITE_ATTENDANCE_API_URL) is NOT set here — it is
# baked into the web image at BUILD time via the GitHub Actions repo variable.
# For multi-server / multi-IP deploys set that repo variable to the relative path
# "/api" so the same web image works on any host (Caddy proxies /api/* locally).

# GHCR images pushed by GitHub Actions
# Example: ghcr.io/kendricklalii/aqua-attendance/web:main
WEB_IMAGE=ghcr.io/your-org-or-user/aqua-attendance/web:main
API_IMAGE=ghcr.io/your-org-or-user/aqua-attendance/api:main

# Database — use a strong password (not this example)
POSTGRES_USER=attendance
POSTGRES_PASSWORD=change-this-db-password
POSTGRES_DB=attendance

# API signing keys — REQUIRED for deploy (docker-compose sets ENV=production).
# Generate TWO different values; do not reuse the same string for both:
#
#   openssl rand -hex 32    # copy → SECRET_KEY
#   openssl rand -hex 32    # copy → QR_SECRET  (run again for a new value)
#
# Each value must be at least 32 characters and must NOT match the placeholders below.
SECRET_KEY=change-this-secret-key
QR_SECRET=change-this-qr-secret

# CORS origin must match your app domain
CORS_ORIGINS=https://app.example.com

# Rate limits (per IP). Increase if kiosk scanners share a public IP (NAT).
# LOGIN_RATE_LIMIT=5/minute
# SCAN_RATE_LIMIT=30/minute

# Optional — passed to API container if set in docker-compose.prod.yml
# SCAN_DEBOUNCE_SECONDS=3
