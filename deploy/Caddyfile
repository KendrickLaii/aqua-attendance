# IP-only / HTTP UAT: listen on :80 (no TLS). No APP_DOMAIN required in the container.
# When you add a real domain + HTTPS, replace :80 with:  {$APP_DOMAIN} { ... }
# and set caddy.environment APP_DOMAIN in docker-compose.prod.yml.
{
	auto_https off
}

:80 {
	encode gzip

	handle /api/* {
		reverse_proxy api:8000
	}
	handle /docs* {
		reverse_proxy api:8000
	}
	handle /openapi.json {
		reverse_proxy api:8000
	}
	handle /redoc* {
		reverse_proxy api:8000
	}

	handle {
		reverse_proxy web:80
	}
}

# Separate API hostname (uncomment when API_DOMAIN differs and you use domain TLS).
# {$API_DOMAIN} {
# 	encode gzip
# 	reverse_proxy api:8000
# }
